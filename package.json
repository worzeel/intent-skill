{
  "name": "intent",
  "version": "0.1.0",
  "description": "AI code provenance tracking for Claude Code — captures why code was written, anchored to git blob hashes.",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "intent": "dist/cli/main.js",
    "intent-hook": "dist/hooks/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "npm run build && node scripts/bundle.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "NODE_OPTIONS=\"--experimental-sqlite --no-warnings\" vitest run",
    "test:watch": "NODE_OPTIONS=\"--experimental-sqlite --no-warnings\" vitest"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
